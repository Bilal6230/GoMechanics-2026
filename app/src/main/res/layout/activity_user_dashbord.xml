<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen"
    tools:context=".User_Dashbord">

    <RelativeLayout
        android:id="@+id/lyRelativeTopImage"
        android:layout_width="match_parent"
        android:layout_height="260dp"
        android:background="@drawable/bg_header_rounded"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:paddingTop="18dp">

        <RelativeLayout
            android:id="@+id/lyRelativelayoutHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/tvWelcomeNote"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:fontFamily="@font/robotoreg"
                android:text="Welcome User"
                android:textColor="#FFFFFF"
                android:textSize="23sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnLogoutUser"
                android:layout_width="wrap_content"
                android:layout_height="42dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:background="@android:color/transparent"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:text="Logout"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />

        </RelativeLayout>

        <TextView
            android:id="@+id/tvDashboardTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/lyRelativelayoutHeader"
            android:layout_marginTop="42dp"
            android:fontFamily="@font/robotoreg"
            android:text="Find the right mechanic\nfor your vehicle"
            android:textColor="#FFFFFF"
            android:textSize="26sp"
            android:textStyle="bold"
            android:lineSpacingExtra="4dp" />

        <TextView
            android:id="@+id/tvDashboardSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/tvDashboardTitle"
            android:layout_marginTop="10dp"
            android:fontFamily="@font/robotoreg"
            android:text="Book trusted mechanics, check bookings,\nand get help from AI Assistant."
            android:textColor="#EAF7FF"
            android:textSize="15sp"
            android:lineSpacingExtra="3dp" />

    </RelativeLayout>

    <androidx.cardview.widget.CardView
        android:id="@+id/mainDashboardCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/lyRelativeTopImage"
        android:layout_marginStart="18dp"
        android:layout_marginEnd="18dp"
        android:layout_marginTop="-42dp"
        app:cardCornerRadius="28dp"
        app:cardElevation="10dp"
        app:cardBackgroundColor="#FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:background="#FFFFFF">

            <TextView
                android:id="@+id/tvQuickActions"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Quick Actions"
                android:textColor="@color/gm_text_primary"
                android:textSize="21sp"
                android:textStyle="bold"
                android:fontFamily="@font/robotoreg" />

            <TextView
                android:id="@+id/tvQuickActionsSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Choose what you want to do"
                android:textColor="@color/gm_text_secondary"
                android:textSize="14sp"
                android:fontFamily="@font/robotoreg" />

            <LinearLayout
                android:id="@+id/firstCardRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:orientation="horizontal"
                android:gravity="center">

                <androidx.cardview.widget.CardView
                    android:id="@+id/CardViewHireMechanic"
                    android:layout_width="0dp"
                    android:layout_height="135dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="10dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="7dp"
                    app:cardBackgroundColor="#F0F9FF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="12dp">

                        <ImageView
                            android:id="@+id/imghire"
                            android:layout_width="55dp"
                            android:layout_height="55dp"
                            android:src="@drawable/hire"
                            android:contentDescription="Hire Mechanic" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:text="Hire Mechanic"
                            android:textColor="@color/gm_text_primary"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/robotoreg" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Find nearby help"
                            android:textColor="@color/gm_text_secondary"
                            android:textSize="12sp"
                            android:fontFamily="@font/robotoreg" />

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:id="@+id/CardViewBooking"
                    android:layout_width="0dp"
                    android:layout_height="135dp"
                    android:layout_weight="1"
                    android:layout_marginStart="10dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="7dp"
                    app:cardBackgroundColor="#FFF7ED">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="12dp">

                        <ImageView
                            android:id="@+id/imgprivousorders"
                            android:layout_width="55dp"
                            android:layout_height="55dp"
                            android:src="@drawable/booking"
                            android:contentDescription="Bookings" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:text="Bookings"
                            android:textColor="@color/gm_text_primary"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/robotoreg" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="View your orders"
                            android:textColor="@color/gm_text_secondary"
                            android:textSize="12sp"
                            android:fontFamily="@font/robotoreg" />

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/secondCardRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:orientation="horizontal"
                android:gravity="center">

                <androidx.cardview.widget.CardView
                    android:id="@+id/CardViewRecentMechanics"
                    android:layout_width="0dp"
                    android:layout_height="135dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="10dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="7dp"
                    app:cardBackgroundColor="#F0FDF4">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="12dp">

                        <ImageView
                            android:id="@+id/imgRecentMechanics"
                            android:layout_width="55dp"
                            android:layout_height="55dp"
                            android:src="@drawable/hire"
                            android:contentDescription="Recent Mechanics" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:text="Recent"
                            android:textColor="@color/gm_text_primary"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/robotoreg" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Recent mechanics"
                            android:textColor="@color/gm_text_secondary"
                            android:textSize="12sp"
                            android:fontFamily="@font/robotoreg" />

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:id="@+id/CardViewAIBot"
                    android:layout_width="0dp"
                    android:layout_height="135dp"
                    android:layout_weight="1"
                    android:layout_marginStart="10dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="7dp"
                    app:cardBackgroundColor="#F5F3FF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="12dp">

                        <TextView
                            android:layout_width="58dp"
                            android:layout_height="58dp"
                            android:gravity="center"
                            android:text="AI"
                            android:textColor="#FFFFFF"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:background="@drawable/bg_chat_ai_badge"
                            android:fontFamily="@font/robotoreg" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:text="AI Assistant"
                            android:textColor="@color/gm_text_primary"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/robotoreg" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Ask for help"
                            android:textColor="@color/gm_text_secondary"
                            android:textSize="12sp"
                            android:fontFamily="@font/robotoreg" />

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

            </LinearLayout>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</RelativeLayout>