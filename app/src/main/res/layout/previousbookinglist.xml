<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="5mm"
        >

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:id="@+id/lyRelativeLayoutMechanicPost1"
            android:orientation="horizontal">


            <androidx.cardview.widget.CardView
                android:layout_width="120dp"
                android:layout_height="match_parent"
                android:layout_marginRight="20dp"
                android:backgroundTint="@color/grey100"
            >

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_alignParentTop="true"
                        android:layout_centerInParent="true"
                        android:layout_marginTop="10dp"
                        android:src="@drawable/mechanic1" />

                </RelativeLayout>

            </androidx.cardview.widget.CardView>

            <RelativeLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Booking Placed"
                        android:textStyle="bold"
                        android:textSize="10pt"
                        android:fontFamily="@font/robotoreg"
                        android:textColor="@color/black"/>
                    <TextView
                        android:id="@+id/etVehicalDecription"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/robotoreg"
                        android:text="Adam"
                        android:textSize="9pt"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/etVehicaleIssues"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/robotoreg"
                        android:text="23"
                        android:textSize="9pt"
                        android:textStyle="bold" />


                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Mechanic Details"
                        android:textStyle="bold"
                        android:textSize="10pt"
                        android:fontFamily="@font/robotoreg"
                        android:textColor="@color/black"/>

                    <TextView
                        android:id="@+id/etVehicaleContact"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/robotoreg"
                        android:text="Bike Expert"
                        android:textSize="9pt"
                        android:textStyle="bold" />


                    <TextView
                        android:id="@+id/MechanicName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/robotoreg"
                        android:text="Bike Expert"
                        android:textSize="9pt"
                        android:textStyle="bold" />

                </LinearLayout>
            </RelativeLayout>
        </LinearLayout>
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/lyRelativeLayoutMechanicPost1"
            android:layout_marginTop="10dp"
            >

            <Button
                android:id="@+id/btnwaitingforresponse"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:background="@drawable/waiting"
                android:text="Waiting for response" />
        </RelativeLayout>
    </RelativeLayout>

</RelativeLayout>