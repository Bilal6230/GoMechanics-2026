<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen"
    tools:context=".LoginScreen">

    <RelativeLayout
        android:id="@+id/loginHeader"
        android:layout_width="match_parent"
        android:layout_height="300dp"
        android:background="@drawable/bg_header_rounded"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="45dp">

        <TextView
            android:id="@+id/tvAppName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="GoMechanics"
            android:textColor="#FFFFFF"
            android:textSize="32sp"
            android:textStyle="bold"
            android:fontFamily="@font/robotoreg" />

        <TextView
            android:id="@+id/tvAppSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/tvAppName"
            android:layout_marginTop="8dp"
            android:text="Book trusted mechanics anytime"
            android:textColor="#EAF7FF"
            android:textSize="16sp"
            android:fontFamily="@font/robotoreg" />

        <TextView
            android:id="@+id/tvUserBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/tvAppSubtitle"
            android:layout_marginTop="28dp"
            android:background="@drawable/bg_chip"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:text="User Login"
            android:textColor="@color/gm_primary_dark"
            android:textSize="14sp"
            android:textStyle="bold"
            android:fontFamily="@font/robotoreg" />

    </RelativeLayout>

    <androidx.cardview.widget.CardView
        android:id="@+id/loginCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="22dp"
        android:layout_marginEnd="22dp"
        android:layout_marginTop="210dp"
        app:cardCornerRadius="28dp"
        app:cardElevation="12dp"
        app:cardBackgroundColor="#FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Welcome Back"
                android:textColor="@color/gm_text_primary"
                android:textSize="25sp"
                android:textStyle="bold"
                android:fontFamily="@font/robotoreg" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:text="Sign in to continue booking mechanics"
                android:textColor="@color/gm_text_secondary"
                android:textSize="14sp"
                android:fontFamily="@font/robotoreg" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:text="Mobile Number"
                android:textColor="@color/gm_text_primary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:fontFamily="@font/robotoreg" />

            <EditText
                android:id="@+id/etContactNumber"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_input"
                android:hint="03XXXXXXXXX"
                android:inputType="phone"
                android:maxLength="11"
                android:maxLines="1"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:textColor="@color/gm_text_primary"
                android:textColorHint="@color/gm_text_muted"
                android:textSize="15sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="Password"
                android:textColor="@color/gm_text_primary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:fontFamily="@font/robotoreg" />

            <EditText
                android:id="@+id/etPass"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_input"
                android:hint="Enter password"
                android:inputType="textPassword"
                android:maxLength="20"
                android:maxLines="1"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:textColor="@color/gm_text_primary"
                android:textColorHint="@color/gm_text_muted"
                android:textSize="15sp" />

            <Button
                android:id="@+id/btnSignIN"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="26dp"
                android:background="@drawable/bg_button_primary"
                android:text="Sign In"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:gravity="center"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Not a member?"
                    android:textColor="@color/gm_text_secondary"
                    android:textSize="14sp"
                    android:fontFamily="@font/robotoreg" />

                <TextView
                    android:id="@+id/tvRegisternow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="Register Now"
                    android:textColor="@color/gm_primary"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/robotoreg" />

            </LinearLayout>

            <TextView
                android:id="@+id/tvSiginAsMecahnic"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="12dp"
                android:text="Login as Mechanic"
                android:textColor="@color/gm_secondary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:fontFamily="@font/robotoreg" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</RelativeLayout>