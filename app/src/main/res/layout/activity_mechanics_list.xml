<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen"
    tools:context=".mechanics_list">

    <RelativeLayout
        android:id="@+id/lyRelativeLayoutheader"
        android:layout_width="match_parent"
        android:layout_height="205dp"
        android:background="@drawable/bg_header_rounded"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:paddingTop="20dp">

        <ImageButton
            android:id="@+id/ImageBtnBack"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:layout_alignParentStart="true"
            android:layout_alignParentTop="true"
            android:background="@android:color/transparent"
            android:contentDescription="Back"
            android:src="@drawable/back"
            android:tint="#FFFFFF" />

        <TextView
            android:id="@+id/tvMechanicsTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/ImageBtnBack"
            android:layout_marginTop="25dp"
            android:fontFamily="@font/robotoreg"
            android:text="Available Mechanics"
            android:textColor="#FFFFFF"
            android:textSize="27sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvMechanicsSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/tvMechanicsTitle"
            android:layout_marginTop="8dp"
            android:fontFamily="@font/robotoreg"
            android:text="Choose a mechanic based on experience"
            android:textColor="#EAF7FF"
            android:textSize="15sp" />

    </RelativeLayout>

    <androidx.cardview.widget.CardView
        android:id="@+id/mechanicsListCard"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/lyRelativeLayoutheader"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="-38dp"
        android:layout_marginBottom="16dp"
        app:cardCornerRadius="28dp"
        app:cardElevation="10dp"
        app:cardBackgroundColor="#FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvListHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mechanics near you"
                android:textColor="@color/gm_text_primary"
                android:textSize="20sp"
                android:textStyle="bold"
                android:fontFamily="@font/robotoreg" />

            <TextView
                android:id="@+id/tvListSubHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="Tap Hire Me to continue booking"
                android:textColor="@color/gm_text_secondary"
                android:textSize="14sp"
                android:fontFamily="@font/robotoreg" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/RVmechaniclist"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginTop="14dp"
                android:clipToPadding="false"
                android:paddingBottom="10dp" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</RelativeLayout>